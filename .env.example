# Zone.eu: smtp.zone.eu — port 587 + STARTTLS, or 465 + SSL (requires code change for 465)
SMTP_HOST=smtp.zone.eu
SMTP_PORT=587
SMTP_USER=info@intervia.ee
SMTP_PASSWORD=
SMTP_FROM=info@intervia.ee
SMTP_USE_TLS=true
EMAIL_TO=info@guzun.ee

# Optional: DeepL for LV/LT (or other) sources with content_locale + translation.provider: deepl
# DEEPL_AUTH_KEY=
# Pro accounts: DEEPL_API_URL=https://api.deepl.com
